# Enforce LF line endings for source files across platforms.
*.go            text eol=lf
*.py            text eol=lf
*.sh            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.md            text eol=lf
*.html          text eol=lf
*.toml          text eol=lf
Makefile        text eol=lf
Dockerfile      text eol=lf

# Binaries
*.png           binary
*.jpg           binary
*.gz            binary
*.tar           binary
